# miloco backend .env 模板(给 pr-hermes fork 用)
#
# === 用法 ===
# 1. cp backend/.env.example backend/.env   (或 ~/.openclaw/miloco/.env)
# 2. 编辑填入 provider 的 API key
# 3. 重启 backend: miloco-cli service restart
# 4. (可选)绑小米账号: miloco-cli account bind
#
# === 三种 provider 示例,任选一种 ===

# ====== A. 默认小米 MiMo(推荐)======
MILOCO_MODEL__OMNI__API_KEY=sk-your-mimo-key-here
MILOCO_MODEL__OMNI__BASE_URL=https://api.xiaomimimo.com/v1
MILOCO_MODEL__OMNI__MODEL=xiaomi/mimo-v2.5

# ====== B. OpenAI 官方 ======
# MILOCO_MODEL__OMNI__API_KEY=sk-your-openai-key
# MILOCO_MODEL__OMNI__BASE_URL=https://api.openai.com/v1
# MILOCO_MODEL__OMNI__MODEL=gpt-4o

# ====== C. 自建 / 第三方 OpenAI 兼容(如 Anthropic via proxy, vllm, ollama 等)======
# MILOCO_MODEL__OMNI__API_KEY=sk-your-key
# MILOCO_MODEL__OMNI__BASE_URL=https://your-endpoint.com/v1
# MILOCO_MODEL__OMNI__MODEL=claude-3-5-sonnet-20241022  # 或 claude-3-5-sonnet 或你的模型名

# === 小米账号 OAuth(配完 .env 后用 miloco-cli account bind 走流程)===
# 不用手填 — account bind 流程会自动写

# === Agent 平台 adapter(主线 #1+#2 完整迁移,必填)===
# platform=hermes 触发 adapter 加载
# 由 install-hermes.sh Step 5 自动写，不需要手填

# === Hermes gateway URL(adapter 直调用)===
# 默认 http://127.0.0.1:8642(hermes gateway 主端口)
# 改 hermes 部署位置时调

# === 后端服务 ===
# MILOCO_SUPERVISED=1  # supervisor 不要改
# MILOCO_LOG_LEVEL=info # debug/info/warning/error
